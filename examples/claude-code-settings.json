{
  "env": {
    "DINGTALK_WEBHOOK": "https://oapi.dingtalk.com/robot/send?access_token=你的token",
    "DINGTALK_SECRET": "SEC你的加签密钥（可选）",
    "DINGTALK_DURATION_ENABLED": "true",
    "DINGTALK_MIN_DURATION": "30"
  },
  "hooks": {
    "Start": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/dingtalk_notify.py --track-start",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/dingtalk_notify.py",
            "async": true
          }
        ]
      }
    ]
  }
}
